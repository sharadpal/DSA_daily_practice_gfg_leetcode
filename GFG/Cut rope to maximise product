Input: n = 5
Output: 6
Explanation: Maximum obtainable product is 2 * 3 = 6.
-------------------------

class Solution {
    public int maxProduct(int n) {
        // code here
        int ans=1;
        if(n==2) return 1;
        if(n==3) return 2;
        while(n>4){
            ans*=3;
            n-=3;
        }
        return ans *n;
    }
}
