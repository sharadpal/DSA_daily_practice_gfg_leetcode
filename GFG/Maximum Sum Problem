class Solution {
    int dp[];
    public int maxSum(int n) {
        // code here.
        dp=new int[n+1];
        return solve(n);
    }
    private int solve(int n){
        if(n==0) return 0;
        if(dp[n]!=0) return dp[n];
        
        int sum=solve(n/2)+ solve(n/3)+solve(n/4);
        return dp[n]=Math.max(sum,n);
    }
}
