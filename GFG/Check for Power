Examples:

Input: x = 2, y = 8
Output: true 
Explanation: 23 is equal to 8.
--------------------------------

class Solution {
    public boolean isPower(int x, int y) {
        // Edge case
        if (y == 1) return true;
        if (x == 1) return false;

        int temp = y;
        while (temp % x == 0) {
            temp = temp / x;
        }
        return temp == 1;
    }
}
