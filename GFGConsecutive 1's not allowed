Examples :

Input: n = 3
Output: 5
Explanation: 5 strings are ("000", "001", "010", "100", "101").
----------------------------

class Solution {
    int countStrings(int n) {
        // code here
        int a = 1;
        int b = 1;
        for(int i =0;i<n;i++)
        {
            int sum = a+b;
            b = a;
            a = sum;
        }
        return a;
    }
}
