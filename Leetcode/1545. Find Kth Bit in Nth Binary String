Example 1:

Input: n = 3, k = 1
Output: "0"
Explanation: S3 is "0111001".
The 1st bit is "0".
--------------------

class Solution {
    public char findKthBit(int n, int k) {
        int len = (int)Math.pow(2, n) - 1;
        return recur(len, k);
    }

    //------->>>>SECOND METHOD
    public char recur(int len, int k){
        if(len == 1) return '0';
        
        int half = len / 2;
        int middle = half + 1;
        
        if(k == middle) return '1';
        else if(k < middle){  // left
            // ADDED 'return' HERE
            return recur(half, k); 
        } else {              // right
            char ans = recur(half, 1 + len - k);
            return (ans == '0') ? '1' : '0';
        }
    }
}
