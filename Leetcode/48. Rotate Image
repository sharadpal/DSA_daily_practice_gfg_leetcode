Input: matrix = [[1,2,3],[4,5,6],[7,8,9]]
Output: [[7,4,1],[8,5,2],[9,6,3]]
--------------------------------

class Solution {
    public void rotate(int[][] matrix) {
        int n=matrix.length;
        // transpose karege
        for(int i=0;i<n;i++){
            for(int j=0;j<i;j++){
                int temp= matrix[i][j];
                matrix[i][j]=matrix[j][i];
                matrix[j][i]=temp;
            }
        }
        // row reverse
        
        for(int i=0;i<n;i++){
            int j=0, k=n-1;
            while(j<k){
                int temp=matrix[i][j];
                matrix[i][j]=matrix[i][k];
                matrix[i][k]=temp;
                j++;
                k--;
            }
        }
    }
}
